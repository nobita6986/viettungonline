{
  "name": "viettung-erp-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev": "start pnpm run dev:backend && start pnpm run dev:frontend",
    "build": "pnpm --filter database build && pnpm --filter shared-types build && pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "start:backend": "pnpm --filter backend start:prod",
    "start:frontend": "pnpm --filter frontend preview",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "unrs-resolver",
      "bcryptjs"
    ]
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.0.0"
  }
}
